# Dev: use same-origin + Vite proxy (recommended — avoids CORS / "No static resource" on APIs).
VITE_API_BASE_URL=/api/v1
# Or call Spring directly (must include /api/v1):
# VITE_API_BASE_URL=http://127.0.0.1:18081/api/v1
VITE_GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

# Optional: dev login UI. Restart Vite after editing. Pair with backend: APP_DEVELOPER_MODE=true
# in backend/.env, or run Spring with --spring.profiles.active=dev (application-dev.properties).
# VITE_DEVELOPER_MODE=false
